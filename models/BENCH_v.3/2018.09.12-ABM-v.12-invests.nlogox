; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; ;;;;;;;;;;;;;;;;;;;;;; Creating Files ;;;;;;;;;;;;;;;;;;;;
; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

to createfiles

   if debugfiles = true[
    if file-exists? "debug.csv" [file-delete "debug.csv"]
    file-open "debug.csv"
    file-print (word "year, " "id, " "group id, " "status, " "invest1, " "invest2, " "provider, " "income, " "gender, " "education, " "economic comfort, " "age, " "dwelling status, " "dwelling label, " "dwelling type, " "dwelling age, " "dwelling size, "
                     "elec, " "gas, " "pattern1, " "pattern2, " "pattern3, " "knowledge, " "cee.aw, " "ed.aw, " "guilt, " "awareness, "
                     "pn1, " "pn2, " "pn3, " "sn1, " "sn2, " "sn3, " "m1st, " "m2st, " "m3st, " "pbcI1, " "pbcI2, " "pbcI3, " "pbcC1, " "pbcC2, " "pbcC3, " "pbcS1, " "pbcS2, " "pbcS3, "
                     "cI1st, " "cI2st, " "cI3.st, " "cC1.st, " "cC2.st, " "cC3.st, " "cS1.st, " "cS2.st, " "cS3.st, "  "U1, " "act1, " "U2, " "act2, " "U3, " "act3, " "U4, " "act4, " "U5, " "act5, " "U6, " "act6, "
                     "U7, " "act7, " "U8, " "act8, " "U9, " "act9, ")
   ]

  file-close-all

end

; ########################################################################################
; #################################### Functions #########################################
; ########################################################################################

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Go

To go

  tick
  set greyuser (count turtles with [ene.prov = 1])
  set brownuser (count turtles with [ene.prov = 2])
  set greenuser (count turtles with [ene.prov = 3])

  recallmemory
  debug
  update.info

  if Scenario = "Ref.SSP2"[
    if NAT = False and TPB = False and COM = True [
      knowledge
      motivation
      consideration]
    utility
    action
    save.energy
    invest
    learn
    update.data
    update.energy
    update.memory
  ]
  set year (year + 1)
  set n (n + 1)
  
  if year >= 2051 [ stop ]

end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Memory

to recallmemory

if year = 2016 and Memory = True [
  if case-study = "ES" [ask turtles[
      set h.id who
      if h.group = 1 [
        let aa random-float 100
        if (aa < 15.1)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 15.1) and (aa < 18.6)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 18.6) and (aa <= 100)[set act1 false  set act2 false  set invest1 False   set invest2 False]]
      if h.group = 2 [
        let aa random-float 100
        if (aa < 16.7)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 16.7) and (aa < 18.7)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 18.7) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 3[
        let aa random-float 100
        if (aa < 23.8)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 23.8) and (aa < 27.1)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 27.1) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 4[
        let aa random-float 100
        if (aa < 30.3)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 30.3) and (aa < 34.8)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 34.8) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 5 or h.group = 6 or h.group = 7 [
        let aa random-float 100
        if (aa < 27.5)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 27.5) and (aa < 32.5)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 32.5) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
    ]]

  if case-study = "NL" [ask turtles[
  set h.id who
      if h.group = 1 [
        let aa random-float 100
        if (aa < 8.8)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 8.8) and (aa < 12.3)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 12.3) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 2 [
        let aa random-float 100
        if (aa < 13.9)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 13.9) and (aa < 17)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 17) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 3[
        let aa random-float 100
        if (aa < 17.8)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 17.8) and (aa < 23.2)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 23.2) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 4[
        let aa random-float 100
        if (aa < 22.1)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 22.1) and (aa < 30.7)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 30.7) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]
      if h.group = 5 or h.group = 6 or h.group = 7 [
        let aa random-float 100
        if (aa < 20.9)[set act1 true  set invest1 true set h.sta "insulated"]
        if (aa >= 20.9) and (aa < 31.4)[set act2 true  set invest2 true set h.sta "installed"]
        if (aa >= 31.4) and (aa <= 100)[set act1 false  set act2 false set invest1 False   set invest2 False]]]]
  ]

end

; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;; behavioral part ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Knowledge

To knowledge

  ask turtles [
      set aware ((know + cee.aw + ed.aw) / 3)
      if case-study = "NL" [
        if (aware < 4.6 )[set guilt "L"]
        if (aware >= 4.6) [set guilt "H"]]
      if case-study = "ES" [
        if (aware < 5.2 )[set guilt "L"]
        if (aware >= 5.2) [set guilt "H"]]
      if (guilt = "H") [set k ( aware / 7)]]

  set aware.total sum [aware] of turtles
  plot.awareness

end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Motivation

To motivation

  ask turtles[
    if guilt = "H"[
      if case-study = "ES" [
        if ((pn1 < 5.67) or (sn1 < 4.77))[set m1.st "L"]
        if ((pn1 >= 5.67) and (sn1 >= 4.77))[set m1.st "H"]
        if ((pn2 < 5.40) or (sn2 < 4.45))[set m2.st "L"]
        if ((pn2 >= 5.40) and (sn2 >= 4.45))[set m2.st "H"]
        if ((pn3 < 5.78) or (sn3 < 5.05))[set m3.st "L"]
        if ((pn3 >= 5.78) and (sn3 >= 5.05))[set m3.st "H"]]

      if case-study = "NL" [
        if ((pn1 < 4.7) or (sn1 < 3.5))[set m1.st "L"]
        if ((pn1 >= 4.7) and (sn1 >= 3.5))[set m1.st "H"]
        if ((pn2 < 4.8) or (sn2 < 3.6))[set m2.st "L"]
        if ((pn2 >= 4.8) and (sn2 >= 3.6))[set m2.st "H"]
        if ((pn3 < 4.8) or (sn3 < 3.7))[set m3.st "L"]
        if ((pn3 >= 4.8) and (sn3 >= 3.7))[set m3.st "H"]]
    ]]

  set pn1.total sum [pn1] of turtles
  set pn2.total sum [pn2] of turtles
  set pn3.total sum [pn3] of turtles
  set sn1.total sum [sn1] of turtles
  set sn2.total sum [sn2] of turtles
  set sn3.total sum [sn3] of turtles

  plot.motivation

end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Consideration

To consideration

  ask turtles[
    if case-study = "ES" [
      if Investment = True and m1.st = "H" [
        if ((pbcI1 < 2.2) or (dw.st = 2))[set cI1.st "L"]                          ;; insulation
        if ((pbcI1 >= 2.2) and (dw.st = 1)) [set cI1.st  "H"]
        if ((pbcI2 < 2.2) or (dw.st = 2) )[set cI2.st  "L"]                        ;; installation
        if ((pbcI2 >= 2.2) and (dw.st = 1)) [set cI2.st "H"]
        if (pbcI3 < 2.2) [set cI3.st "L"]                                          ;; appliances
        if (pbcI3 >= 2.2) [set cI3.st "H"]]

      if Conservation = True and m2.st = "H" [
        if ((pbcC1 < 1) or (ene.pat1 = 3)) [set cC1.st "L"]                        ;; switch off extra(3 = almost always)
        if (pbcC1 >= 1) [set cC1.st "H"]
        if ((pbcC2 < 1) or (ene.pat2 = 3)) [set cC2.st "L"]                        ;; turn down
        if (pbcC2 >= 1) [set cC2.st "H"]
        if ((pbcC3 < 1) or (ene.pat3 = 3)) [set cC3.st "L"]                        ;; use less
        if (pbcC3 >= 1) [set cC3.st "H"]]

      if Switching = True and m3.st = "H" [
        if ene.prov = 1 [
          if (pbcS1 < 3.5) [set cS1.st "L"]                                        ;; grey to brown
          if (pbcS1 >= 3.5) [set cS1.st "H"]]
        if ene.prov = 2 [
          if (pbcS2 < 3.5) [set cS2.st "L"]                                        ;; brown to green
          if (pbcS2 >= 3.5) [set cS2.st "H"]]
        if ene.prov = 1 [
          if (pbcS3 < 3.5) [set cS3.st "L"]                                        ;; grey to grey
          if (pbcS3 >= 3.5) [set cS3.st "H"]]]
    ]

    if case-study = "NL" [
      if Investment = True and m1.st = "H" [
        if ((pbcI1 < 1) or (dw.st = 2))[set cI1.st "L"]                          ;; insulation
        if ((pbcI1 >= 1) and (dw.st = 1)) [set cI1.st  "H"]
        if ((pbcI2 < 1) or (dw.st = 2))[set cI2.st  "L"]                         ;; installation
        if ((pbcI2 >= 1) and (dw.st = 1)) [set cI2.st "H"]
        if (pbcI3 < 1) [set cI3.st "L"]                                          ;; appliances
        if (pbcI3 >= 1) [set cI3.st "H"]]

      if Conservation = True and m2.st = "H" [
        if ((pbcC1 < 1) or (ene.pat1 = 3)) [set cC1.st "L"]                        ;; switch off extra(3 = almost always)
        if (pbcC1 >= 1) [set cC1.st "H"]
        if ((pbcC2 < 1) or (ene.pat2 = 3)) [set cC2.st "L"]                        ;; turn down
        if (pbcC2 >= 1) [set cC2.st "H"]
        if ((pbcC3 < 1) or (ene.pat3 = 3)) [set cC3.st "L"]                        ;; use less
        if (pbcC3 >= 1) [set cC3.st "H"]]

      if Switching = True and m3.st = "H" [
        if ene.prov = 1 [
          if (pbcS1 < 1) [set cS1.st "L"]                                        ;; grey to brown
          if (pbcS1 >= 1) [set cS1.st "H"]]
        if ene.prov = 2 [
          if (pbcS2 < 1) [set cS2.st "L"]                                        ;; brown to green
          if (pbcS2 >= 1) [set cS2.st "H"]]
        if ene.prov = 1 [
          if (pbcS3 < 1) [set cS3.st "L"]                                        ;; grey to grey
          if (pbcS3 >= 1) [set cS3.st "H"]]]
    ]
  ]



end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Random utility

To utility

 ask turtles[

    if cI1.st = "L" [set U1 0]
    if cI1.st = "H" [set U1 ((edu * 0.0563284 + age * 0.0008106 + dw.elab * -0.0769971 + dw.type * 0.4265 + dw.age * 0.0883428 + dw.size * 0.0857047 + gas * 0.0000488 + pn1 * 0.052849 ) + erI1 )]

    if cI2.st = "L" [set U2 0]
    if cI2.st = "H" [set U2  ((gen * 0.2792288 + edu * 0.0779388 + age * 0.001021 + dw.type * 0.5005143 + dw.age * -0.0577463 + dw.size * 0.1287344 + elec * -0.0000937 + pn2 * 0.082771) + erI2 )]

    if cI3.st = "L" [set U3 0]
    if cI3.st = "H" [set U3  ((ecom * 0.1059369 + elec * 0.0000697 + pn3 * 0.095038) + erI3 )]

;    if cC1.st = "L" [set U4 0]
;    if cC1.st = "H" [set U4 ((ecom * 0.1049109 + pn1 * 0.1134906) + erC1 )]
;
;    if cC2.st = "L" [set U5 0]
;    if cC2.st = "H" [set U5  ((gen * -0.1723292 + age * -0.0004648 + dw.elab * 0.0965134 + dw.type * 0.3023552 + dw.age * -0.0716471 + gas * 0.0000819 + pn2 * 0.1534471) + erC2 )]
;
;    if cC3.st = "L" [set U6 0]
;    if cC3.st = "H" [set U6  ((gen * -0.2067435 + pn3 * 0.1619213) + erC3 )]
;
;    if cS1.st = "L" [set U7 0]
;    if cS1.st = "H" [set U7 ((edu * 0.0856276 + ecom * 0.0010655 + dw.elab * -0.0974067 + elec * -0.0000671) + erS1 )]
;
;    if cS2.st = "L" [set U8 0]
;    if cS2.st = "H" [set U8  ((edu * 0.0639826 + age * 0.0006837 + dw.age * -0.0869868 + pn2 * 0.080775) + erS2 )]
;
;    if cS3.st = "L" [set U9 0]
;    if cS3.st = "H" [set U9  ((income * -0.0634739 + age * 0.0005574 + gas * 0.0001035) + erS3 )]
  ]

end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Action

To action

  ask turtles [
    if U1 <= 0 or gas <= 500 or invest1 = True [set act1 False]
    if (U1 > 0 and invest1 = False and gas > 500 and U1 >= U2) [set act1 True   set invest1 True  set color 65]
    if U2 <= 0  or elec <= 1000 or invest2 = True [set act2 False]
    if (U2 > 0 and invest2 = False and elec > 1000 and U2 >= U1) [set act2 True set invest2 True set color 45]
    if U3 <= 0 or elec <= 1000 or act2 = True or invest3 = True [set act3 False]
    if U3 > 0 and elec > 1000 and act2 = False and invest3 = False [set act3 True  set invest3 True set color 125]

;    if U4 <= 0  or elec <= 1000 or act2 = True or act3 = True[set act4 False]
;    if U4 > 0 and elec > 1000  and act2 = False and act3 = False [set act4 True  set color 45]
;    if U5 <= 0 or gas <= 500 and act1 = True [set act5 False]
;    if U5 > 0 and gas > 500 and act1 = False [set act5 True  set color 45]
;    if U6 <= 0  or elec <= 1000 or act2 = True or act3 = True [set act6 False]
;    if U6 > 0 and elec > 1000 and act2 = False and act3 = False [set act6 True  set color 45]
;
;    if U7 <= 0 or elec <= 0 [set act7 False]
;    if U7 > 0 and elec > 0 and ene.prov = 1  [set act7 True  set color 125  set ene.prov 2]
;    if U8 <= 0 or elec <= 0 [set act8 False]
;    if U8 > 0  and elec > 0 and ene.prov = 2 [set act8 True  set color 125 set ene.prov 3]
;    if U9 <= 0 or elec <= 0 [set act9 False]
;    if U9 > 0  and elec > 0 and ene.prov = 1 [set act9 True  set color 125  set ene.prov 1]

    if ((act2 = True or invest2 = True) and (elec <= 1000)) [set ene.prov 3]
  ]

  set noaction count turtles with [act1 = False and act2 = False and act3 = False]  ;  and act4 = False and act5 = False and act6 = False and act7 = False and act8 = False and act9 = False]
  set a1 count turtles with [act1 = True]  set a2 count turtles with [act2 = True]  set a3 count turtles with [act3 = True]
;  set a4 count turtles with [act4 = True]  set a5 count turtles with [act5 = True]  set a6 count turtles with [act6 = True]
;  set a7 count turtles with [act7 = True]  set a8 count turtles with [act8 = True]  set a9 count turtles with [act9 = True]
  set a.total (a1 + a2 + a3) ; + a4 + a5 + a6 + a7 + a8 + a9)

  set a1.com  a1.com + a1           set a2.com  a2.com + a2           set a3.com  a3.com + a3
;  set a4.com  a4.com + a4           set a5.com  a5.com + a5           set a6.com  a6.com + a6
;  set a7.com  a7.com + a7           set a8.com  a8.com + a8           set a9.com  a9.com + a9

  plot.investment
  plot.conservation
  plot.switching
  plot.behaviors

; socio-demographic dynamics
;; Education and Age

  ask turtles[
    if (edu = 1 and age = 1) [set sdgroup 1]  if (edu = 1 and age = 2) [set sdgroup 2]  if (edu = 1 and age = 3) [set sdgroup 3]  if (edu = 1 and age = 4) [set sdgroup 4]
    if (edu = 2 and age = 1) [set sdgroup 5]  if (edu = 2 and age = 2) [set sdgroup 6]  if (edu = 2 and age = 3) [set sdgroup 7]  if (edu = 2 and age = 4) [set sdgroup 8]
    if (edu = 3 and age = 1) [set sdgroup 9]  if (edu = 3 and age = 2) [set sdgroup 10] if (edu = 3 and age = 3) [set sdgroup 11] if (edu = 3 and age = 4) [set sdgroup 12]]

  set number.g1 count turtles with [sdgroup = 1]  set number.g2 count turtles with [sdgroup = 2]  set number.g3 count turtles with [sdgroup = 3]  set number.g4 count turtles with [sdgroup = 4]
  set number.g5 count turtles with [sdgroup = 5]  set number.g6 count turtles with [sdgroup = 6]  set number.g7 count turtles with [sdgroup = 7]  set number.g8 count turtles with [sdgroup = 8]
  set number.g9 count turtles with [sdgroup = 9]  set number.g10 count turtles with [sdgroup = 10]  set number.g11 count turtles with [sdgroup = 11]  set number.g12 count turtles with [sdgroup = 12]

  set g1.a1 count turtles with [sdgroup = 1 and act1 = True]  set g1.a2 count turtles with [sdgroup = 1 and act2 = True]   set g1.a3 count turtles with [sdgroup = 1 and act3 = True]
  set g1.a4 count turtles with [sdgroup = 1 and act4 = True]  set g1.a5 count turtles with [sdgroup = 1 and act5 = True]   set g1.a6 count turtles with [sdgroup = 1 and act6 = True]
  set g1.a7 count turtles with [sdgroup = 1 and act7 = True]  set g1.a8 count turtles with [sdgroup = 1 and act8 = True]   set g1.a9 count turtles with [sdgroup = 1 and act9 = True]
  set g2.a1 count turtles with [sdgroup = 2 and act1 = True]  set g2.a2 count turtles with [sdgroup = 2 and act2 = True]   set g2.a3 count turtles with [sdgroup = 2 and act3 = True]
  set g2.a4 count turtles with [sdgroup = 2 and act4 = True]  set g2.a5 count turtles with [sdgroup = 2 and act5 = True]   set g2.a6 count turtles with [sdgroup = 2 and act6 = True]
  set g2.a7 count turtles with [sdgroup = 2 and act7 = True]  set g2.a8 count turtles with [sdgroup = 2 and act8 = True]   set g2.a9 count turtles with [sdgroup = 2 and act9 = True]
  set g3.a1 count turtles with [sdgroup = 3 and act1 = True]  set g3.a1 count turtles with [sdgroup = 3 and act2 = True]   set g3.a3 count turtles with [sdgroup = 3 and act3 = True]
  set g3.a4 count turtles with [sdgroup = 3 and act4 = True]  set g3.a5 count turtles with [sdgroup = 3 and act5 = True]   set g3.a6 count turtles with [sdgroup = 3 and act6 = True]
  set g3.a7 count turtles with [sdgroup = 3 and act7 = True]  set g3.a8 count turtles with [sdgroup = 3 and act8 = True]   set g3.a9 count turtles with [sdgroup = 3 and act9 = True]
  set g4.a1 count turtles with [sdgroup = 4 and act1 = True]  set g4.a2 count turtles with [sdgroup = 4 and act2 = True]   set g4.a3 count turtles with [sdgroup = 4 and act3 = True]
  set g4.a4 count turtles with [sdgroup = 4 and act4 = True]  set g4.a5 count turtles with [sdgroup = 4 and act5 = True]   set g4.a6 count turtles with [sdgroup = 4 and act6 = True]
  set g4.a7 count turtles with [sdgroup = 4 and act7 = True]  set g4.a8 count turtles with [sdgroup = 4 and act8 = True]   set g4.a9 count turtles with [sdgroup = 4 and act9 = True]
  set g5.a1 count turtles with [sdgroup = 5 and act1 = True]  set g5.a2 count turtles with [sdgroup = 5 and act2 = True]   set g5.a3 count turtles with [sdgroup = 5 and act3 = True]
  set g5.a4 count turtles with [sdgroup = 5 and act4 = True]  set g5.a5 count turtles with [sdgroup = 5 and act5 = True]   set g5.a6 count turtles with [sdgroup = 5 and act6 = True]
  set g5.a7 count turtles with [sdgroup = 5 and act7 = True]  set g5.a8 count turtles with [sdgroup = 5 and act8 = True]   set g5.a9 count turtles with [sdgroup = 5 and act9 = True]
  set g6.a1 count turtles with [sdgroup = 6 and act1 = True]  set g6.a2 count turtles with [sdgroup = 6 and act2 = True]   set g6.a3 count turtles with [sdgroup = 6 and act3 = True]
  set g6.a4 count turtles with [sdgroup = 6 and act4 = True]  set g6.a5 count turtles with [sdgroup = 6 and act5 = True]   set g6.a6 count turtles with [sdgroup = 6 and act6 = True]
  set g6.a7 count turtles with [sdgroup = 6 and act7 = True]  set g6.a8 count turtles with [sdgroup = 6 and act8 = True]   set g6.a9 count turtles with [sdgroup = 6 and act9 = True]
  set g7.a1 count turtles with [sdgroup = 7 and act1 = True]  set g7.a2 count turtles with [sdgroup = 7 and act2 = True]   set g7.a3 count turtles with [sdgroup = 7 and act3 = True]
  set g7.a4 count turtles with [sdgroup = 7 and act4 = True]  set g7.a5 count turtles with [sdgroup = 7 and act5 = True]   set g7.a6 count turtles with [sdgroup = 7 and act6 = True]
  set g7.a7 count turtles with [sdgroup = 7 and act7 = True]  set g7.a8 count turtles with [sdgroup = 7 and act8 = True]   set g7.a9 count turtles with [sdgroup = 7 and act9 = True]
  set g8.a1 count turtles with [sdgroup = 8 and act1 = True]  set g8.a2 count turtles with [sdgroup = 8 and act2 = True]   set g8.a3 count turtles with [sdgroup = 8 and act3 = True]
  set g8.a4 count turtles with [sdgroup = 8 and act4 = True]  set g8.a5 count turtles with [sdgroup = 8 and act5 = True]   set g8.a6 count turtles with [sdgroup = 8 and act6 = True]
  set g8.a7 count turtles with [sdgroup = 8 and act7 = True]  set g8.a8 count turtles with [sdgroup = 8 and act8 = True]   set g8.a9 count turtles with [sdgroup = 8 and act9 = True]
  set g9.a1 count turtles with [sdgroup = 9 and act1 = True]  set g9.a2 count turtles with [sdgroup = 9 and act2 = True]   set g9.a3 count turtles with [sdgroup = 9 and act3 = True]
  set g9.a4 count turtles with [sdgroup = 9 and act4 = True]  set g9.a5 count turtles with [sdgroup = 9 and act5 = True]   set g9.a6 count turtles with [sdgroup = 9 and act6 = True]
  set g9.a7 count turtles with [sdgroup = 9 and act7 = True]  set g9.a8 count turtles with [sdgroup = 9 and act8 = True]   set g9.a9 count turtles with [sdgroup = 9 and act9 = True]
  set g10.a1 count turtles with [sdgroup = 10 and act1 = True]  set g10.a2 count turtles with [sdgroup = 10 and act2 = True]   set g10.a3 count turtles with [sdgroup = 10 and act3 = True]
  set g10.a4 count turtles with [sdgroup = 10 and act4 = True]  set g10.a5 count turtles with [sdgroup = 10 and act5 = True]   set g10.a6 count turtles with [sdgroup = 10 and act6 = True]
  set g10.a7 count turtles with [sdgroup = 10 and act7 = True]  set g10.a8 count turtles with [sdgroup = 10 and act8 = True]   set g10.a9 count turtles with [sdgroup = 10 and act9 = True]
  set g11.a1 count turtles with [sdgroup = 11 and act1 = True]  set g11.a2 count turtles with [sdgroup = 11 and act2 = True]   set g11.a3 count turtles with [sdgroup = 11 and act3 = True]
  set g11.a4 count turtles with [sdgroup = 11 and act4 = True]  set g11.a5 count turtles with [sdgroup = 11 and act5 = True]   set g11.a6 count turtles with [sdgroup = 11 and act6 = True]
  set g11.a7 count turtles with [sdgroup = 11 and act7 = True]  set g11.a8 count turtles with [sdgroup = 11 and act8 = True]   set g11.a9 count turtles with [sdgroup = 11 and act9 = True]
  set g12.a1 count turtles with [sdgroup = 12 and act1 = True]  set g12.a2 count turtles with [sdgroup = 12 and act2 = True]   set g12.a3 count turtles with [sdgroup = 12 and act3 = True]
  set g12.a4 count turtles with [sdgroup = 12 and act4 = True]  set g12.a5 count turtles with [sdgroup = 12 and act5 = True]   set g12.a6 count turtles with [sdgroup = 12 and act6 = True]
  set g12.a7 count turtles with [sdgroup = 12 and act7 = True]  set g12.a8 count turtles with [sdgroup = 12 and act8 = True]   set g12.a9 count turtles with [sdgroup = 12 and act9 = True]

end


; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Save

To save.energy


  set elec.total sum [elec] of turtles
  set gas.total sum [gas] of turtles

  if year >= 2017 [
    ask turtles[
      if (act1 = True) [
        set save.a1 (gas * 20 / 100)
        set gas (gas - save.a1)]
      if (act1 = False) [set save.a1 0]

      if (act2 = True) [
        if elec >= 1700 [set save.a2 1700]
        if elec < 1700  [set save.a2 elec]
        set elec (elec - save.a2)]
      if (act2 = False) [set save.a2 0]

      if (act3 = True) [
        set save.a3 (elec * 5 / 100)
        set elec (elec - save.a3)]
      if (act3 = False) [set save.a3 0]

;      if (act4 = True) [
;        set save.a4 (elec * 2 / 100)
;        set elec (elec - save.a4)]
;      if (act4 = False) [set save.a4 0]
;
;      if (act5 = True) [
;        set save.a5 (gas *  2 / 100)
;        set gas (gas - save.a5)]
;      if (act5 = False) [set save.a5 0]
;
;      if (act6 = True) [
;        set save.a6 (elec * 2 / 100)
;        set elec (elec - save.a6)]
;      if (act6 = False) [set save.a6 0]
  ]]

  set save.elec (sum [save.a2] of turtles + sum [save.a3] of turtles) ; + sum [save.a4] of turtles + sum [save.a6] of turtles)
  set save.gas (sum [save.a1] of turtles) ; + sum [save.a5] of turtles)

  set save.elec.com (save.elec.com + save.elec)
  set save.gas.com (save.gas.com + save.gas)

; socio-demographic dynamics
;; Education and Age

; energy consumption

  set elec.g1 sum [elec] of turtles with [sdgroup = 1]  set elec.g2 sum [elec] of turtles with [sdgroup = 2]  set elec.g3 sum [elec] of turtles with [sdgroup = 3]
  set elec.g4 sum [elec] of turtles with [sdgroup = 4]  set elec.g5 sum [elec] of turtles with [sdgroup = 5]  set elec.g6 sum [elec] of turtles with [sdgroup = 6]
  set elec.g7 sum [elec] of turtles with [sdgroup = 7]  set elec.g8 sum [elec] of turtles with [sdgroup = 8]  set elec.g9 sum [elec] of turtles with [sdgroup = 9]
  set elec.g10 sum [elec] of turtles with [sdgroup = 10]  set elec.g11 sum [elec] of turtles with [sdgroup = 11]  set elec.g12 sum [elec] of turtles with [sdgroup = 12]

  set gas.g1 sum [gas] of turtles with [sdgroup = 1]  set gas.g2 sum [gas] of turtles with [sdgroup = 2]  set gas.g3 sum [gas] of turtles with [sdgroup = 3]
  set gas.g4 sum [gas] of turtles with [sdgroup = 4]  set gas.g5 sum [gas] of turtles with [sdgroup = 5]  set gas.g6 sum [gas] of turtles with [sdgroup = 6]
  set gas.g7 sum [gas] of turtles with [sdgroup = 7]  set gas.g8 sum [gas] of turtles with [sdgroup = 8]  set gas.g9 sum [gas] of turtles with [sdgroup = 9]
  set gas.g10 sum [gas] of turtles with [sdgroup = 10]  set gas.g11 sum [gas] of turtles with [sdgroup = 11]  set gas.g12 sum [gas] of turtles with [sdgroup = 12]

  set elec.all (elec.g1 + elec.g2 + elec.g3 + elec.g4 + elec.g5 + elec.g6 + elec.g7 + elec.g8 + elec.g9 + elec.g10 + elec.g11 + elec.g12)
  set gas.all (gas.g1 + gas.g2 + gas.g3 + gas.g4 + gas.g5 + gas.g6 + gas.g7 + gas.g8 + gas.g9 + gas.g10 + gas.g11 + gas.g12)

; saving energy

  set save.elec.g1 (sum [save.a2] of turtles with [sdgroup = 1] + sum [save.a3] of turtles with [sdgroup = 1] ) ;+ sum [save.a4] of turtles with [sdgroup = 1] + sum [save.a6] of turtles with [sdgroup = 1])
  set save.gas.g1  (sum [save.a1] of turtles with [sdgroup = 1]) ; + sum [save.a5] of turtles with [sdgroup = 1])

  set save.elec.g2 (sum [save.a2] of turtles with [sdgroup = 2] + sum [save.a3] of turtles with [sdgroup = 2] ) ; + sum [save.a4] of turtles with [sdgroup = 2] + sum [save.a6] of turtles with [sdgroup = 2])
  set save.gas.g2  (sum [save.a1] of turtles with [sdgroup = 2] ) ; + sum [save.a5] of turtles with [sdgroup = 2])

  set save.elec.g3 (sum [save.a2] of turtles with [sdgroup = 3] + sum [save.a3] of turtles with [sdgroup = 3]) ; + sum [save.a4] of turtles with [sdgroup = 3] + sum [save.a6] of turtles with [sdgroup = 3])
  set save.gas.g3  (sum [save.a1] of turtles with [sdgroup = 3] ) ; + sum [save.a5] of turtles with [sdgroup = 3])

  set save.elec.g4 (sum [save.a2] of turtles with [sdgroup = 4] + sum [save.a3] of turtles with [sdgroup = 4] ) ;+ sum [save.a4] of turtles with [sdgroup = 4] + sum [save.a6] of turtles with [sdgroup = 4])
  set save.gas.g4  (sum [save.a1] of turtles with [sdgroup = 4] ) ;+ sum [save.a5] of turtles with [sdgroup = 4])

  set save.elec.g5 (sum [save.a2] of turtles with [sdgroup = 5] + sum [save.a3] of turtles with [sdgroup = 5] ) ;+ sum [save.a4] of turtles with [sdgroup = 5] + sum [save.a6] of turtles with [sdgroup = 5])
  set save.gas.g5  (sum [save.a1] of turtles with [sdgroup = 5] ) ;+ sum [save.a5] of turtles with [sdgroup = 5])

  set save.elec.g6 (sum [save.a2] of turtles with [sdgroup = 6] + sum [save.a3] of turtles with [sdgroup = 6] ); + sum [save.a4] of turtles with [sdgroup = 6] + sum [save.a6] of turtles with [sdgroup = 6])
  set save.gas.g6  (sum [save.a1] of turtles with [sdgroup = 6] ) ;+ sum [save.a5] of turtles with [sdgroup = 6])

  set save.elec.g7 (sum [save.a2] of turtles with [sdgroup = 7] + sum [save.a3] of turtles with [sdgroup = 7] ); + sum [save.a4] of turtles with [sdgroup = 7] + sum [save.a6] of turtles with [sdgroup = 7])
  set save.gas.g7  (sum [save.a1] of turtles with [sdgroup = 7] ) ;+ sum [save.a5] of turtles with [sdgroup = 7])

  set save.elec.g8 (sum [save.a2] of turtles with [sdgroup = 8] + sum [save.a3] of turtles with [sdgroup = 8] ) ;+ sum [save.a4] of turtles with [sdgroup = 8] + sum [save.a6] of turtles with [sdgroup = 8])
  set save.gas.g8  (sum [save.a1] of turtles with [sdgroup = 8] ) ;+ sum [save.a5] of turtles with [sdgroup = 8])

  set save.elec.g9 (sum [save.a2] of turtles with [sdgroup = 9] + sum [save.a3] of turtles with [sdgroup = 9] ) ;+ sum [save.a4] of turtles with [sdgroup = 9] + sum [save.a6] of turtles with [sdgroup = 9])
  set save.gas.g9  (sum [save.a1] of turtles with [sdgroup = 9] ); + sum [save.a5] of turtles with [sdgroup = 9])

  set save.elec.g10 (sum [save.a2] of turtles with [sdgroup = 10] + sum [save.a3] of turtles with [sdgroup = 10] ) ;+ sum [save.a4] of turtles with [sdgroup = 10] + sum [save.a6] of turtles with [sdgroup = 10])
  set save.gas.g10  (sum [save.a1] of turtles with [sdgroup = 10] ); + sum [save.a5] of turtles with [sdgroup = 10])

  set save.elec.g11 (sum [save.a2] of turtles with [sdgroup = 11] + sum [save.a3] of turtles with [sdgroup = 11] ); + sum [save.a4] of turtles with [sdgroup = 11] + sum [save.a6] of turtles with [sdgroup = 11])
  set save.gas.g11  (sum [save.a1] of turtles with [sdgroup = 11] ); + sum [save.a5] of turtles with [sdgroup = 11])

  set save.elec.g12 (sum [save.a2] of turtles with [sdgroup = 12] + sum [save.a3] of turtles with [sdgroup = 12] ); + sum [save.a4] of turtles with [sdgroup = 12] + sum [save.a6] of turtles with [sdgroup = 12])
  set save.gas.g12  (sum [save.a1] of turtles with [sdgroup = 12] ); + sum [save.a5] of turtles with [sdgroup = 12])

  plot.saveenergy


end
; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Invesments

To invest

  if year >= 2017 [
    ask turtles[
      if (act1 = True) [set invs.a1 I1.cost]   if act1 = False [set invs.a1 0]
      if (act2 = True) [set invs.a2 I2.cost]   if act2 = False [set invs.a2 0]
      if (act3 = True) [set invs.a3 I3.cost]   if act3 = False [set invs.a3 0]
  ]]

  set invs (sum [invs.a1] of turtles + sum [invs.a2] of turtles + sum [invs.a3] of turtles)

  set invs.com (invs.com + invs)
  set invs1.com  invs1.com + (sum [invs.a1] of turtles)
  set invs2.com  invs2.com + (sum [invs.a2] of turtles)
  set invs3.com  invs3.com + (sum [invs.a3] of turtles)

; socio-demographic dynamics
;; Education and Age

  set invs.a1.g1  (sum [invs.a1] of turtles with [sdgroup = 1])  set invs.a1.g2  (sum [invs.a1] of turtles with [sdgroup = 2])
  set invs.a2.g1  (sum [invs.a2] of turtles with [sdgroup = 1])  set invs.a2.g2  (sum [invs.a2] of turtles with [sdgroup = 2])
  set invs.a3.g1  (sum [invs.a3] of turtles with [sdgroup = 1])  set invs.a3.g2  (sum [invs.a3] of turtles with [sdgroup = 2])

  set invs.a1.g3  (sum [invs.a1] of turtles with [sdgroup = 3])  set invs.a1.g4  (sum [invs.a1] of turtles with [sdgroup = 4])
  set invs.a2.g3  (sum [invs.a2] of turtles with [sdgroup = 3])  set invs.a2.g4  (sum [invs.a2] of turtles with [sdgroup = 4])
  set invs.a3.g3  (sum [invs.a3] of turtles with [sdgroup = 3])  set invs.a3.g4  (sum [invs.a3] of turtles with [sdgroup = 4])

  set invs.a1.g5  (sum [invs.a1] of turtles with [sdgroup = 5])  set invs.a1.g6  (sum [invs.a1] of turtles with [sdgroup = 6])
  set invs.a2.g5  (sum [invs.a2] of turtles with [sdgroup = 5])  set invs.a2.g6  (sum [invs.a2] of turtles with [sdgroup = 6])
  set invs.a3.g5  (sum [invs.a3] of turtles with [sdgroup = 5])  set invs.a3.g6  (sum [invs.a3] of turtles with [sdgroup = 6])

  set invs.a1.g7  (sum [invs.a1] of turtles with [sdgroup = 7])  set invs.a1.g8  (sum [invs.a1] of turtles with [sdgroup = 8])
  set invs.a2.g7  (sum [invs.a2] of turtles with [sdgroup = 7])  set invs.a2.g8  (sum [invs.a2] of turtles with [sdgroup = 8])
  set invs.a3.g7  (sum [invs.a3] of turtles with [sdgroup = 7])  set invs.a3.g8  (sum [invs.a3] of turtles with [sdgroup = 8])

  set invs.a1.g9  (sum [invs.a1] of turtles with [sdgroup = 9])  set invs.a1.g10  (sum [invs.a1] of turtles with [sdgroup = 10])
  set invs.a2.g9  (sum [invs.a2] of turtles with [sdgroup = 9])  set invs.a2.g10  (sum [invs.a2] of turtles with [sdgroup = 10])
  set invs.a3.g9  (sum [invs.a3] of turtles with [sdgroup = 9])  set invs.a3.g10  (sum [invs.a3] of turtles with [sdgroup = 10])

  set invs.a1.g11  (sum [invs.a1] of turtles with [sdgroup = 11])  set invs.a1.g12  (sum [invs.a1] of turtles with [sdgroup = 12])
  set invs.a2.g11  (sum [invs.a2] of turtles with [sdgroup = 11])  set invs.a2.g12  (sum [invs.a2] of turtles with [sdgroup = 12])
  set invs.a3.g11  (sum [invs.a3] of turtles with [sdgroup = 11])  set invs.a3.g12  (sum [invs.a3] of turtles with [sdgroup = 12])

end

; ::::::::::::::::::::::::::::::::::::::::::::::::::
; Social dynamics and learning

To learn

  if year >= 2017[
    ask turtles[
      if Learning = "No learning" [ ]
      if Learning = "Slow dynamics"[
        if (act1 = True or invest1 = True) [
          if (pbcI1 < 6.6) [set pbcI1 (pbcI1 + (pbcI1 * 0.02))]

          create-links-to other turtles-on neighbors
          ask link-neighbors [
            set ngb.k.mean mean [know] of turtles-on neighbors
            let ngb.k.median median [know] of turtles-on neighbors
            set ngb.k max list ngb.k.mean ngb.k.median
            set ngb.ca.mean mean [cee.aw] of turtles-on neighbors
            let ngb.ca.median median [cee.aw] of turtles-on neighbors
            set ngb.ca max list ngb.ca.mean  ngb.ca.median
            set ngb.ea.mean mean [ed.aw] of turtles-on neighbors
            let ngb.ea.median median [ed.aw] of turtles-on neighbors
            set ngb.ed max list ngb.ea.mean  ngb.ea.median
            let ngb.pn1.mean mean [pn1]  of turtles-on neighbors
            let ngb.pn1.median median [pn1] of turtles-on neighbors
            set ngb.pn1 max list ngb.pn1.mean  ngb.pn1.median
            let ngb.sn1.mean mean [sn1] of turtles-on neighbors
            let ngb.sn1.median median [sn1] of turtles-on neighbors
            set ngb.sn1 max list ngb.sn1.mean  ngb.sn1.median
            let ngb.pbcI1.mean mean [pbcI1] of turtles-on neighbors
            let ngb.pbcI1.median median [pbcI1] of turtles-on neighbors
            set ngb.pbcI1 max list ngb.pbcI1.mean  ngb.pbcI1.median]

          if count link-neighbors > 4 [ ask link-neighbors [
            if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
            if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
            if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
            if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
            if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
            if ((pbcI1 < 6.5) and (pbcI1 < ngb.pbcI1)) [set pbcI1 (pbcI1 + (pbcI1 * 0.02))]]]
          if count link-neighbors > 4 [ ask n-of 4 link-neighbors [
              if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
              if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
              if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
              if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
              if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
              if ((pbcI1 < 6.5) and (pbcI1 < ngb.pbcI1)) [set pbcI1 (pbcI1 + (pbcI1 * 0.02))]]]
        ]

        if (act2 = True or invest2 = True) [
          if (pbcI2 < 6.6) [set pbcI2 (pbcI2 + (pbcI2 * 0.02))]

          create-links-to other turtles-on neighbors
          ask link-neighbors [
            set ngb.k.mean mean [know] of turtles-on neighbors
            let ngb.k.median median [know] of turtles-on neighbors
            set ngb.k max list ngb.k.mean ngb.k.median
            set ngb.ca.mean mean [cee.aw] of turtles-on neighbors
            let ngb.ca.median median [cee.aw] of turtles-on neighbors
            set ngb.ca max list ngb.ca.mean  ngb.ca.median
            set ngb.ea.mean mean [ed.aw] of turtles-on neighbors
            let ngb.ea.median median [ed.aw] of turtles-on neighbors
            set ngb.ed max list ngb.ea.mean  ngb.ea.median
            let ngb.pn1.mean mean [pn1] of turtles-on neighbors
            let ngb.pn1.median median [pn1] of turtles-on neighbors
            set ngb.pn1 max list ngb.pn1.mean  ngb.pn1.median
            let ngb.sn1.mean mean [sn1] of turtles-on neighbors
            let ngb.sn1.median median [sn1] of turtles-on neighbors
            set ngb.sn1 max list ngb.sn1.mean  ngb.sn1.median
            let ngb.pbcI2.mean mean [pbcI2] of turtles-on neighbors
            let ngb.pbcI2.median median [pbcI2] of turtles-on neighbors
            set ngb.pbcI2 max list ngb.pbcI2.mean  ngb.pbcI2.median]

          if count link-neighbors <= 4 [ask link-neighbors[
            if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
            if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
            if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
            if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
            if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
            if ((pbcI2 < 6.5) and (pbcI2 < ngb.pbcI2)) [set pbcI2 (pbcI2 + (pbcI2 * 0.02))]]]
          if count link-neighbors > 4 [ ask n-of 4 link-neighbors[
            if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
            if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
            if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
            if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
            if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
            if ((pbcI2 < 6.5) and (pbcI2 < ngb.pbcI2)) [set pbcI2 (pbcI2 + (pbcI2 * 0.02))]]]
        ]

        if (act3 = True) [
          if (pbcI3 < 6.6) [set pbcI3 (pbcI3 + (pbcI3 * 0.02))]

          create-links-to other turtles-on neighbors
          ask link-neighbors [
            set ngb.k.mean mean [know] of turtles-on neighbors
            let ngb.k.median median [know] of turtles-on neighbors
            set ngb.k max list ngb.k.mean ngb.k.median
            set ngb.ca.mean mean [cee.aw] of turtles-on neighbors
            let ngb.ca.median median [cee.aw] of turtles-on neighbors
            set ngb.ca max list ngb.ca.mean  ngb.ca.median
            set ngb.ea.mean mean [ed.aw] of turtles-on neighbors
            let ngb.ea.median median [ed.aw] of turtles-on neighbors
            set ngb.ed max list ngb.ea.mean  ngb.ea.median
            let ngb.pn1.mean mean [pn1] of turtles-on neighbors
            let ngb.pn1.median median [pn1] of turtles-on neighbors
            set ngb.pn1 max list ngb.pn1.mean  ngb.pn1.median
            let ngb.sn1.mean mean [sn1] of turtles-on neighbors
            let ngb.sn1.median median [sn1] of turtles-on neighbors
            set ngb.sn1 max list ngb.sn1.mean  ngb.sn1.median
            let ngb.pbcI3.mean mean [pbcI3] of turtles-on neighbors
            let ngb.pbcI3.median median [pbcI3] of turtles-on neighbors
            set ngb.pbcI3 max list ngb.pbcI3.mean  ngb.pbcI3.median]

          if count link-neighbors <= 4 [ask link-neighbors[
              if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
              if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
              if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
              if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
              if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
              if ((pbcI3 < 6.5) and (pbcI3 < ngb.pbcI3)) [set pbcI3 (pbcI3 + (pbcI3 * 0.02))]]]
          if count link-neighbors > 4 [ ask n-of 4 link-neighbors[
              if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
              if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
              if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
              if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
              if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
              if ((pbcI3 < 6.5) and (pbcI3 < ngb.pbcI3)) [set pbcI3 (pbcI3 + (pbcI3 * 0.02))]]]
          ]

;        if (act4 = True) [
;          if (pbcC1 < 6.6) [set pbcC1 (pbcC1 + (pbcC1 * 0.02))]
;
;          create-links-to other turtles-on neighbors
