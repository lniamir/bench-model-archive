;            let ngb.ca.median median [cee.aw] of turtles-on neighbors
;            set ngb.ca max list ngb.ca.mean  ngb.ca.median
;            set ngb.ea.mean mean [ed.aw] of turtles-on neighbors
;            let ngb.ea.median median [ed.aw] of turtles-on neighbors
;            set ngb.ed max list ngb.ea.mean  ngb.ea.median
;            let ngb.pn2.mean mean [pn2] of turtles-on neighbors
;            let ngb.pn2.median median [pn2] of turtles-on neighbors
;            set ngb.pn2 max list ngb.pn2.mean  ngb.pn2.median
;            let ngb.sn2.mean mean [sn2] of turtles-on neighbors
;            let ngb.sn2.median median [sn2] of turtles-on neighbors
;            set ngb.sn2 max list ngb.sn2.mean  ngb.sn2.median
