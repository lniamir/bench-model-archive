            set ngb.sn1 max list ngb.sn1.mean  ngb.sn1.median
            let ngb.pbcI2.mean mean [pbcI2] of turtles-on neighbors
            let ngb.pbcI2.median median [pbcI2] of turtles-on neighbors
            set ngb.pbcI2 max list ngb.pbcI2.mean  ngb.pbcI2.median]

          if count link-neighbors <= 4 [ask link-neighbors[
            if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
            if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
            if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
            if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
            if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
            if ((pbcI2 < 6.5) and (pbcI2 < ngb.pbcI2)) [set pbcI2 (pbcI2 + (pbcI2 * 0.02))]]]
          if count link-neighbors > 4 [ ask n-of 4 link-neighbors[
            if ((know < ngb.k) and (know < 6.6))[set know (know + (know * 0.02))]
            if ((cee.aw < ngb.ca) and (cee.aw < 6.6))[set cee.aw (cee.aw + (cee.aw * 0.02))]
            if ((ed.aw < ngb.ed) and (ed.aw < 6.6))[set ed.aw (ed.aw + (ed.aw * 0.02))]
            if ((pn1 < ngb.pn1) and (pn1 < 6.6))[set pn1 (pn1 + (pn1 * 0.02))]
            if ((sn1 < ngb.sn1) and (sn1 < 6.6)) [set sn1 (sn1 + (0.02 * sn1))]
            if ((pbcI2 < 6.5) and (pbcI2 < ngb.pbcI2)) [set pbcI2 (pbcI2 + (pbcI2 * 0.02))]]]
        ]

        if (act3 = True) [
          if (pbcI3 < 6.6) [set pbcI3 (pbcI3 + (pbcI3 * 0.02))]

