; ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Updates

To update.data

  ask turtles[
    if case-study = "ES"[
      if scenario = "Ref.SSP2"[
        if (rn < 11.4 ) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn >= 11.4) and (rn <= 58.2) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn > 58.2) and (rn <= 86) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn > 86) and (rn <= 94.7) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn > 94.7) and (rn <= 97.8) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn >  97.8) and (rn <= 98.7) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
        if (rn > 98.7) and (rn <= 100) [
          set income (income * (item 0 item n cge-es-ssp2-h))]
    ]]

    if case-study = "NL"[
      if scenario = "Ref.SSP2"[
        if (rn < 5.5 ) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn >= 5.5) and (rn <= 40.19) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn > 40.19) and (rn <= 78.17) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn > 78.17) and (rn <= 91.69) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn > 91.69) and (rn <= 97.39) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn >  97.39) and (rn <= 98.36) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
        if (rn > 98.36) and (rn <= 100) [
          set income (income * (item 0 item n cge-nl-ssp2-h))]
    ]]
  ]
end


To update.energy

  if year >= 2017 [
    ask turtles [
    if (act1 = True and gas <= 200)[set h.sta "Efficient"]
    if (act2 = True and elec <= 0)[set h.sta "Prosumer"  set ene.prov  3]
    if (act3 = True and elec <= 1000)[set h.sta "Efficient"]
    if (act4 = True and elec <= 1000)[set h.sta "Efficient"]
    if (act5 = True and gas <= 200)[set h.sta "Efficient"]
    if (act6 = True and elec <= 1000)[set h.sta "Efficient"]
    if (act7 = True and elec <= 1000)[set h.sta "Efficient"]
    if (act8 = True and elec <= 1000)[set h.sta "Efficient"]
    if (act9 = True and elec <= 1000)[set h.sta "Efficient"]
  ]]

end

;update memory and actions

To update.memory

  ask turtles[
    if invest1 = True [set act1.year (act1.year + 1)]
    if invest2 = True [set act2.year (act2.year + 1)]
    if invest3 = True [set act3.year (act3.year + 1)]
    if act1.year >= 5  [set invest1  False set act1.year 0]
    if act2.year >= 10 [set invest2  False  set act2.year 0]
    if act3.year >= 3  [set invest3 False set act3.year 0]
  ]

end



To update.info

  ask turtles[
    set act1 False  set act2 False   set act3 False
    set act4 False  set act5 False   set act6 False
    set act7 False  set act8 False   set act9 False
  ]

  set g1.a1 0 set g1.a2 0  set g1.a3 0  set g1.a4 0  set g1.a5 0  set g1.a6 0 set g1.a7 0 set g1.a8 0 set g1.a9 0
