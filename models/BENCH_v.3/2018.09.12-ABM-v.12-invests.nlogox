  set g12.a1 0 set g12.a2 0  set g12.a3 0  set g12.a4 0  set g12.a5 0  set g12.a6 0 set g12.a7 0 set g12.a8 0 set g12.a9 0

  set save.elec.g1 0 set save.elec.g2 0 set save.elec.g3 0 set save.elec.g4 0   set save.elec.g5 0   set save.elec.g6 0
  set save.elec.g7 0 set save.elec.g8 0 set save.elec.g9 0 set save.elec.g10 0  set save.elec.g12 0  set save.elec.g12 0
  set save.gas.g1 0  set save.gas.g2 0  set save.gas.g3 0  set save.gas.g4 0    set save.gas.g5 0    set save.gas.g6 0
  set save.gas.g7 0  set save.gas.g8 0  set save.gas.g9 0  set save.gas.g10 0   set save.gas.g11 0   set save.gas.g12 0

  set save.elec 0    set save.gas 0
