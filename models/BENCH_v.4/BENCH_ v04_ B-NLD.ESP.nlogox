          set erC1 randomNumber -0.04 -0.03 0.01  set erC2 randomNumber -0.06 -0.03 0.01    set erC3 randomNumber -0.03 -0.01 0.01
          set erS1 -0.01                          set erS2 randomNumber -0.02 -0.01 0.01    set erS3 -0.01

