      set sav_2_lce_inc4 0
      set sav_3_lce_inc4 0

      set sav_1_ff_inc5 0
      set sav_2_ff_inc5 0
      set sav_3_ff_inc5 0
      set sav_1_lce_inc5 0
      set sav_2_lce_inc5 0
      set sav_3_lce_inc5 0

      set utility_exp_lce1 0                   ;; utility expectations
